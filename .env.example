# Copie este arquivo para .env e preencha os valores
# No Railway, configure estas como variáveis de ambiente no painel

# Senha de acesso ao mapa (você define)
APP_PASSWORD=suasenhaaqui

# JSON completo da chave de serviço do Google Cloud
# Cole o conteúdo inteiro do arquivo .json gerado no Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Porta (o Railway define automaticamente)
PORT=3000
